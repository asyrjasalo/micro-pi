{
  "name": "msbox",
  "version": "0.1.0",
  "description": "Run pi coding agent in microsandbox",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "msbox": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "check": "biome check && tsc --noEmit && bun test",
    "reset": "bun run src/reset.ts",
    "stop": "bun run src/stop.ts",
    "tsc": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "dependencies": {
    "microsandbox": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
